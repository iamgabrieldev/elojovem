# URL pública do app (redirects AbacatePay, etc.)
NEXTAUTH_URL="http://localhost:3000"

# AbacatePay — https://docs.abacatepay.com/
ABACATEPAY_API_KEY=""
ABACATEPAY_WEBHOOK_SECRET=""
ABACATEPAY_PAYMENT_METHODS="PIX"
ABACATEPAY_PRODUCT_PRICE_CENTS="2900"
ABACATEPAY_PRODUCT_EXTERNAL_ID="elojovem-acesso"
ABACATEPAY_PRODUCT_NAME="Acesso Elo Jovem"
ABACATEPAY_PRODUCT_DESCRIPTION="Acesso ao app e conteúdos personalizados."

# IA Mentor / Devocional automático (Google AI Studio)
GOOGLE_GENERATIVE_AI_API_KEY=""

# Google Maps (Places API)
GOOGLE_MAPS_API_KEY=""

# Bíblia (opcional) — https://www.abibliadigital.com.br/api/users
ABIBLIA_DIGITAL_TOKEN=""

# Firebase — app web (cliente) — um par de aspas por valor (sem "" duplicado)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Firebase Admin — servidor (sessão + Firestore server-side)
# FIREBASE_CLIENT_EMAIL = só o email da service account (não cole o JSON inteiro)
# FIREBASE_PRIVATE_KEY = chave PEM em uma linha com \n onde haveria quebra de linha
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
